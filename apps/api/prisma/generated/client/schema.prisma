generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("PATIENT")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?

  prescriptionsAsDoctor   Prescription[]  @relation("DoctorPrescriptions")
  prescriptionsAsPatient  Prescription[]  @relation("PatientPrescriptions")
  medicalRecordsAsDoctor  MedicalRecord[] @relation("DoctorRecords")
  medicalRecordsAsPatient MedicalRecord[] @relation("PatientRecords")
  auditLogs               AuditLog[]
}

model DoctorProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization String
  licenseNumber  String  @unique
  hospital       String
  phone          String
  signature      String?
  experience     Int     @default(0)
  bio            String?
}

model PatientProfile {
  id               String  @id @default(uuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth      String
  bloodGroup       String
  allergies        String  @default("[]")
  phone            String
  emergencyContact String?
  address          String?
  weight           Float?
  height           Float?
}

model Prescription {
  id                 String   @id @default(uuid())
  prescriptionNumber String   @unique
  doctorId           String
  patientId          String
  doctor             User     @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  patient            User     @relation("PatientPrescriptions", fields: [patientId], references: [id])
  diagnosis          String
  medications        String
  notes              String?
  followUpDate       String?
  status             String   @default("ACTIVE")
  qrCode             String?
  verificationHash   String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MedicalRecord {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  patient     User     @relation("PatientRecords", fields: [patientId], references: [id])
  doctor      User     @relation("DoctorRecords", fields: [doctorId], references: [id])
  title       String
  description String
  recordType  String
  attachments String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
